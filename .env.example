# Copy to .env.local for local dev. NEVER commit the real .env.local — it's
# gitignored, and this repo is public (flu-wop/egoff). If a real secret ever
# lands in git history, rotate it at the provider immediately.

# Turso — turso.tech → create database "egoff-orders" → `turso db show egoff-orders --url` / `turso db tokens create egoff-orders`
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook secret comes AFTER first deploy — see README step 3 below
STRIPE_WEBHOOK_SECRET=

# Resend — resend.com → API Keys → create key
RESEND_API_KEY=
# Use onboarding@resend.dev until EGOFF's sending domain is verified in Resend
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=egoffessentials@gmail.com

# Site URL — used in Stripe success/cancel redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin panel password — choose something real, not this placeholder
ADMIN_PASSWORD=
